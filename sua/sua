#!/usr/bin/env python3

import sys
import os
import json
import tkinter as tk
from tkinter import ttk
import subprocess
from datetime import datetime, timedelta
import getpass
from pathlib import Path
import subprocess as sp
import shutil

CONFIG_DIR = Path.home() / ".config" / "sua"
PERMS_FILE = CONFIG_DIR / "permissions.json"

def ensure_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

def load_permissions():
    ensure_config()
    if PERMS_FILE.exists():
        try:
            return json.loads(PERMS_FILE.read_text())
        except:
            return {}
    return {}

def save_permissions(perms):
    ensure_config()
    PERMS_FILE.write_text(json.dumps(perms, indent=2))

def is_allowed(cmd_base):
    perms = load_permissions()
    entry = perms.get(cmd_base)
    if entry:
        expires = datetime.fromisoformat(entry["expires"])
        if datetime.now() < expires:
            return True
        del perms[cmd_base]
        save_permissions(perms)
    return False

def allow_all_day(cmd_base):
    perms = load_permissions()
    expires = datetime.now().replace(hour=23, minute=59, second=59)
    perms[cmd_base] = {"expires": expires.isoformat()}
    save_permissions(perms)

def get_caller_info():
    user = os.environ.get("SUDO_USER") or os.environ.get("USER") or getpass.getuser()
    ppid = os.getppid()
    try:
        with open(f"/proc/{ppid}/comm") as f:
            caller = f.read().strip()
    except:
        caller = "shell"
    return user, caller

def find_elevator():
    for cmd in ["pkexec", "sudo"]:
        if shutil.which(cmd):
            return cmd
    return None

def detect_system_theme():
    try:
        result = sp.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
            capture_output=True, text=True, timeout=1
        )
        if "dark" in result.stdout.lower():
            return "dark"
    except:
        pass
    try:
        result = sp.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "gtk-theme"],
            capture_output=True, text=True, timeout=1
        )
        if "dark" in result.stdout.lower():
            return "dark"
    except:
        pass
    return "light"

class SuaDialog:
    def __init__(self, user, caller, command_str, elevator):
        self.result = False
        self.all_day = False

        theme = detect_system_theme()
        if theme == "dark":
            bg = "#1e1e2e"
            fg = "#cdd6f4"
            card_bg = "#313244"
            cmd_bg = "#45475a"
            sep_color = "#585b70"
            muted = "#a6adc8"
            accent = "#89b4fa"
        else:
            bg = "#f5f5f5"
            fg = "#1e1e2e"
            card_bg = "#ffffff"
            cmd_bg = "#e6e9ef"
            sep_color = "#dce0e8"
            muted = "#6c7086"
            accent = "#1e66f5"

        self.root = tk.Tk()
        self.root.title("sua — подтверждение")
        self.root.resizable(False, False)
        self.root.configure(bg=bg)

        if theme == "dark":
            self.root.tk_setPalette(
                background=bg, foreground=fg,
                activeBackground=card_bg, activeForeground=fg,
                selectBackground=accent, selectForeground=fg
            )

        style = ttk.Style()
        available = style.theme_names()
        if "clam" in available:
            style.theme_use("clam")
        style.configure("TFrame", background=bg)
        style.configure("TCheckbutton", background=bg, foreground=fg, font=("", 9))
        style.map("TCheckbutton",
                  background=[("active", bg)],
                  foreground=[("active", fg)])

        main = ttk.Frame(self.root, padding=20)
        main.pack(fill="both", expand=True)

        card = tk.Frame(main, bg=card_bg, relief="flat", padx=16, pady=16, highlightbackground=sep_color, highlightthickness=1)
        card.pack(fill="x", pady=(0, 16))

        tk.Label(card, text=f"Пользователь: {user}", font=("", 10, "bold"),
                 bg=card_bg, fg=fg, anchor="w").pack(fill="x")
        tk.Label(card, text=f"Вызвано из: {caller}", font=("", 9),
                 bg=card_bg, fg=muted, anchor="w").pack(fill="x", pady=(2, 0))

        sep = tk.Frame(card, height=1, bg=sep_color)
        sep.pack(fill="x", pady=10)

        tk.Label(card, text="Команда:", font=("", 9),
                 bg=card_bg, fg=muted, anchor="w").pack(fill="x")
        cmd_label = tk.Label(card, text=f"  {command_str}", font=("", 10, "bold"),
                             bg=cmd_bg, fg=fg, anchor="w", padx=10, pady=8)
        cmd_label.pack(fill="x", pady=(4, 0))

        if elevator:
            status = tk.Label(card, text=f"Выполнить от root через {elevator}",
                              font=("", 8), bg=card_bg, fg=muted, anchor="w")
            status.pack(fill="x", pady=(6, 0))

        self.all_day_var = tk.BooleanVar()
        cb_frame = ttk.Frame(main)
        cb_frame.pack(fill="x", pady=(0, 16))
        all_day_cb = ttk.Checkbutton(cb_frame, text="Разрешить на весь день (с любыми флагами)",
                                     variable=self.all_day_var)
        all_day_cb.pack(anchor="w")

        btn_frame = ttk.Frame(main)
        btn_frame.pack(fill="x")

        deny_btn = tk.Button(btn_frame, text="Отклонить", command=self.on_deny,
                             bg="#e64553", fg="white", font=("", 10, "bold"),
                             padx=22, pady=6, bd=0, cursor="hand2",
                             activebackground="#d20f39", activeforeground="white")
        deny_btn.pack(side="right", padx=(8, 0))

        allow_btn = tk.Button(btn_frame, text="Разрешить", command=self.on_allow,
                              bg="#40a02b", fg="white", font=("", 10, "bold"),
                              padx=22, pady=6, bd=0, cursor="hand2",
                              activebackground="#2e7d1e", activeforeground="white")
        allow_btn.pack(side="right")

        self.root.update_idletasks()
        w = self.root.winfo_reqwidth()
        h = self.root.winfo_reqheight()
        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        x = (sw - w) // 2
        y = (sh - h) // 2
        self.root.geometry(f"{w}x{h}+{x}+{y}")

        self.root.protocol("WM_DELETE_WINDOW", self.on_deny)
        self.root.grab_set()
        self.root.focus_force()
        self.root.bind("<Escape>", lambda e: self.on_deny())
        self.root.bind("<Return>", lambda e: self.on_allow())

    def on_allow(self):
        self.result = True
        self.all_day = self.all_day_var.get()
        self.root.destroy()

    def on_deny(self):
        self.result = False
        self.root.destroy()

    def run(self):
        self.root.mainloop()
        return self.result, self.all_day


def show_dialog(user, caller, command_str, elevator):
    return SuaDialog(user, caller, command_str, elevator).run()


def execute_via(cmd_list, elevator):
    if elevator == "sudo":
        os.execvp(elevator, [elevator] + cmd_list)
    elif elevator == "pkexec":
        os.execvp(elevator, [elevator] + cmd_list)
    else:
        os.execvp(cmd_list[0], cmd_list)


def main():
    if len(sys.argv) < 2:
        print("Использование: sua <команда> [аргументы...]", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] in ("-h", "--help"):
        print("sua — аналог sudo с графическим подтверждением")
        print()
        print("Использование:")
        print("  sua <команда> [аргументы...]")
        print()
        print("Примеры:")
        print("  sua ls -la /root")
        print("  sua apt install htop")
        sys.exit(0)

    command_str = " ".join(sys.argv[1:])
    cmd_base = os.path.basename(sys.argv[1].split()[0]) if " " not in sys.argv[1] else os.path.basename(sys.argv[1].split()[0])

    user, caller = get_caller_info()

    if cmd_base == "sua":
        print("Ошибка: рекурсивный вызов sua запрещён", file=sys.stderr)
        sys.exit(1)

    elevator = find_elevator()

    SHELL_BUILTINS = {
        "cd": "встроенная команда оболочки",
        "exit": "встроенная команда оболочки",
        "export": "встроенная команда оболочки",
        "alias": "встроенная команда оболочки",
        "unalias": "встроенная команда оболочки",
        "source": "встроенная команда оболочки",
        ".": "встроенная команда оболочки",
        "type": "встроенная команда оболочки",
        "eval": "встроенная команда оболочки",
        "exec": "встроенная команда оболочки",
        "set": "встроенная команда оболочки",
        "unset": "встроенная команда оболочки",
        "bg": "встроенная команда оболочки",
        "fg": "встроенная команда оболочки",
        "jobs": "встроенная команда оболочки",
        "disown": "встроенная команда оболочки",
        "echo": "встроенная команда оболочки",
        "printf": "встроенная команда оболочки",
        "read": "встроенная команда оболочки",
        "shift": "встроенная команда оболочки",
        "declare": "встроенная команда оболочки",
        "local": "встроенная команда оболочки",
        "readonly": "встроенная команда оболочки",
        "return": "встроенная команда оболочки",
        "break": "встроенная команда оболочки",
        "continue": "встроенная команда оболочки",
        "times": "встроенная команда оболочки",
        "trap": "встроенная команда оболочки",
        "umask": "встроенная команда оболочки",
        "wait": "встроенная команда оболочки",
        "hash": "встроенная команда оболочки",
        "test": "встроенная команда оболочки",
        "kill": "встроенная команда оболочки",
        "pushd": "встроенная команда оболочки",
        "popd": "встроенная команда оболочки",
        "dirs": "встроенная команда оболочки",
        "history": "встроенная команда оболочки",
        "fc": "встроенная команда оболочки",
    }

    def report_error(cmd):
        if cmd in SHELL_BUILTINS:
            print(f"sua: {cmd}: команда не найдена", file=sys.stderr)
            print(f"sua: «{cmd}» — {SHELL_BUILTINS[cmd]}, она не может быть запущена напрямую.", file=sys.stderr)
            if cmd == "cd":
                print("sua: используйте: sua sh -c \"cd <путь> && <команда>\"", file=sys.stderr)
            else:
                print("sua: используйте: sua sh -c \"<команда>\" для выполнения в подоболочке", file=sys.stderr)
        else:
            print(f"sua: {cmd}: команда не найдена", file=sys.stderr)
        sys.exit(127)

    try:
        if is_allowed(cmd_base):
            execute_via(sys.argv[1:], elevator)
    except FileNotFoundError:
        report_error(cmd_base)

    allowed, all_day = show_dialog(user, caller, command_str, elevator)

    if not allowed:
        print("Отклонено", file=sys.stderr)
        sys.exit(1)

    if all_day:
        allow_all_day(cmd_base)

    try:
        execute_via(sys.argv[1:], elevator)
    except FileNotFoundError:
        report_error(cmd_base)


if __name__ == "__main__":
    main()
