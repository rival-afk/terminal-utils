#!/usr/bin/env python3

import sys
import os
import json
import tkinter as tk
from tkinter import ttk
import subprocess
from datetime import datetime, timedelta
import getpass
import hashlib
import base64
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "sua"
PERMS_FILE = CONFIG_DIR / "permissions.json"
PASSWD_FILE = CONFIG_DIR / "password.enc"

def ensure_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

def load_permissions():
    ensure_config()
    if PERMS_FILE.exists():
        try:
            return json.loads(PERMS_FILE.read_text())
        except:
            return {}
    return {}

def save_permissions(perms):
    ensure_config()
    PERMS_FILE.write_text(json.dumps(perms, indent=2))

def get_command_key(cmd_base):
    return cmd_base

def is_allowed(cmd_base):
    perms = load_permissions()
    key = get_command_key(cmd_base)
    entry = perms.get(key)
    if entry:
        expires = datetime.fromisoformat(entry["expires"])
        if datetime.now() < expires:
            return True
        else:
            del perms[key]
            save_permissions(perms)
    return False

def allow_command(cmd_base, all_day=False):
    perms = load_permissions()
    key = get_command_key(cmd_base)
    if all_day:
        expires = datetime.now().replace(hour=23, minute=59, second=59)
    else:
        expires = datetime.now() + timedelta(minutes=5)
    perms[key] = {"expires": expires.isoformat()}
    save_permissions(perms)

def get_caller_info():
    user = os.environ.get("SUDO_USER") or os.environ.get("USER") or getpass.getuser()
    ppid = os.getppid()
    try:
        with open(f"/proc/{ppid}/comm") as f:
            caller = f.read().strip()
    except:
        caller = "shell"
    return user, caller

def hash_password(password):
    salt = os.urandom(16)
    key = hashlib.pbkdf2_hmac("sha256", password.encode(), salt, 100000)
    return base64.b64encode(salt + key).decode()

def verify_password(stored, password):
    data = base64.b64decode(stored)
    salt = data[:16]
    key = data[16:]
    new_key = hashlib.pbkdf2_hmac("sha256", password.encode(), salt, 100000)
    return key == new_key

def get_stored_password():
    ensure_config()
    if PASSWD_FILE.exists():
        return PASSWD_FILE.read_text().strip()
    return None

def set_stored_password(password):
    ensure_config()
    PASSWD_FILE.write_text(hash_password(password))
    os.chmod(PASSWD_FILE, 0o600)

class SuaDialog:
    def __init__(self, user, caller, command_str):
        self.result = False
        self.all_day = False
        self.password = None

        self.root = tk.Tk()
        self.root.title("sua — подтверждение")
        self.root.resizable(False, False)

        win_w, win_h = 520, 280
        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        x = (sw - win_w) // 2
        y = (sh - win_h) // 2
        self.root.geometry(f"{win_w}x{win_h}+{x}+{y}")

        self.root.configure(bg="#f5f5f5")

        main_frame = tk.Frame(self.root, bg="#f5f5f5", padx=20, pady=20)
        main_frame.pack(fill="both", expand=True)

        info_frame = tk.Frame(main_frame, bg="#ffffff", relief="solid", bd=1, padx=15, pady=15)
        info_frame.pack(fill="x", pady=(0, 15))

        tk.Label(info_frame, text=f"Пользователь: {user}", font=("", 10, "bold"),
                 bg="#ffffff", anchor="w").pack(fill="x")
        tk.Label(info_frame, text=f"Вызвано из: {caller}", font=("", 9),
                 bg="#ffffff", anchor="w", fg="#555555").pack(fill="x", pady=(2, 0))

        sep = tk.Frame(info_frame, height=1, bg="#dddddd")
        sep.pack(fill="x", pady=8)

        tk.Label(info_frame, text="Команда:", font=("", 9),
                 bg="#ffffff", anchor="w", fg="#555555").pack(fill="x")
        cmd_label = tk.Label(info_frame, text=f"  {command_str}", font=("", 10, "bold"),
                             bg="#f0f0f0", anchor="w", padx=8, pady=6)
        cmd_label.pack(fill="x", pady=(2, 0))

        self.all_day_var = tk.BooleanVar()
        all_day_cb = tk.Checkbutton(main_frame, text="Разрешить эту команду (с любыми флагами) на весь день",
                                    variable=self.all_day_var, bg="#f5f5f5",
                                    font=("", 9), anchor="w")
        all_day_cb.pack(fill="x", pady=(0, 15))

        btn_frame = tk.Frame(main_frame, bg="#f5f5f5")
        btn_frame.pack(fill="x")

        deny_btn = tk.Button(btn_frame, text="Отклонить", command=self.on_deny,
                             bg="#e74c3c", fg="white", font=("", 10, "bold"),
                             padx=20, pady=5, bd=0, cursor="hand2")
        deny_btn.pack(side="right", padx=(8, 0))

        allow_btn = tk.Button(btn_frame, text="Разрешить", command=self.on_allow,
                              bg="#2ecc71", fg="white", font=("", 10, "bold"),
                              padx=20, pady=5, bd=0, cursor="hand2")
        allow_btn.pack(side="right")

        self.root.protocol("WM_DELETE_WINDOW", self.on_deny)
        self.root.grab_set()
        self.root.focus_force()
        self.root.bind("<Escape>", lambda e: self.on_deny())
        self.root.bind("<Return>", lambda e: self.on_allow())

    def on_allow(self):
        self.result = True
        self.all_day = self.all_day_var.get()
        self.root.destroy()

    def on_deny(self):
        self.result = False
        self.root.destroy()

    def run(self):
        self.root.mainloop()
        return self.result, self.all_day


def show_dialog(user, caller, command_str):
    dialog = SuaDialog(user, caller, command_str)
    return dialog.run()


def main():
    if len(sys.argv) < 2:
        print("Использование: sua <команда> [аргументы...]", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] in ("-h", "--help"):
        print("sua — аналог sudo с графическим подтверждением")
        print()
        print("Использование:")
        print("  sua <команда> [аргументы...]")
        print()
        print("Примеры:")
        print("  sua ls -la /root")
        print("  sua apt install htop")
        sys.exit(0)

    command_str = " ".join(sys.argv[1:])
    cmd_base = os.path.basename(sys.argv[1].split()[0]) if " " not in sys.argv[1] else os.path.basename(sys.argv[1].split()[0])

    user, caller = get_caller_info()

    if cmd_base in ("sua",):
        print("Ошибка: рекурсивный вызов sua запрещён", file=sys.stderr)
        sys.exit(1)

    if is_allowed(cmd_base):
        os.execvp(sys.argv[1], sys.argv[1:])

    allowed, all_day = show_dialog(user, caller, command_str)

    if not allowed:
        print("Отклонено", file=sys.stderr)
        sys.exit(1)

    allow_command(cmd_base, all_day=all_day)
    os.execvp(sys.argv[1], sys.argv[1:])


if __name__ == "__main__":
    main()
